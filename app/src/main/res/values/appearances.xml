<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TextAppearance.JSG" parent="">
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
    </style>

    <style name="TextAppearance.JSG.Topbar">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="fontFamily">@font/pretendard_semibold</item>
    </style>

    <style name="TextAppearance.JSG.Head1">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="fontFamily">@font/pretendard_bold</item>
    </style>

    <style name="TextAppearance.JSG.Head2">
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/gray_900</item>
        <item name="fontFamily">@font/pretendard_medium</item>
    </style>

    <style name="TextAppearance.JSG.Body1">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="fontFamily">@font/pretendard_semibold</item>
    </style>

    <style name="TextAppearance.JSG.Body2">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="fontFamily">@font/pretendard_medium</item>
    </style>

    <style name="TextAppearance.JSG.Button">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="fontFamily">@font/pretendard_semibold</item>
    </style>

    <style name="JSG.TimePicker" parent="Theme.AppCompat.Light.Dialog">
        <item name="android:background">@color/transparency</item>
        <item name="android:headerBackground">@color/transparency</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:colorAccent">@color/black</item>
        <item name="android:textColorPrimary">@color/black</item>
        <item name="fontFamily">@font/pretendard_semibold</item>
        <!-- NumberPicker divider color -->
        <item name="colorControlNormal">@color/blue_main</item>
    </style>

    <style name="JSG.DatePicker" parent="Theme.AppCompat.Light.Dialog">
        <!-- 상단 Title 배경색 -->
        <item name="colorAccent">@color/transparency</item>
        <!-- 선택한 날짜 배경 색 -->
        <item name="colorControlActivated">@color/blue_main</item>
        <!-- Highlight item color-->
        <item name="colorControlHighlight">@color/blue_main</item>
        <!--Calender Background color -->
        <item name="android:colorBackground">@color/white</item>
        <!-- Week TextColor-->
        <item name="android:textColorSecondary">@color/black</item>
        <!-- Calender Number color arrow color (< >) -->
        <item name="android:textColorPrimary">@color/black</item>
        <!--day , month TextColor-->
        <item name="android:textColorPrimaryInverse">@color/black</item>
        <!-- year-->
        <item name="android:textColorSecondaryInverse">@color/black</item>
        <item name="android:textSize">0sp</item>
        <item name="cornerSize">16dp</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="fontFamily">@font/pretendard_semibold</item>
    </style>

    <style name="Theme.App.TransparentStatusBar" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <style name="WhitePopupMenu" parent="Widget.AppCompat.PopupMenu.Overflow">
        <item name="android:popupBackground">@drawable/shape_rect_20_white_fill</item>
    </style>


    <style name="TextAppearance.JSG.Bnv">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/gray_700</item>
        <item name="fontFamily">@font/pretendard_medium</item>
    </style>



</resources>