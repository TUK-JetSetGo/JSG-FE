<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">
        <!-- top bar -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_addTravel_topbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="20dp"
            android:background="@color/white"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_addTravel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="일정 생성"
                android:textSize="20sp"
                style="@style/TextAppearance.JSG.Topbar"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
            <ImageView
                android:id="@+id/iv_addTravel_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_arrow_left"
                android:layout_marginStart="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_addTravel"
                app:layout_constraintBottom_toBottomOf="@id/tv_addTravel"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/gray_300"
            app:layout_constraintTop_toBottomOf="@id/layout_addTravel_topbar"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- 본문 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="여행 날짜를\n선택해주세요"
            style="@style/TextAppearance.JSG.Head1"
            android:lineSpacingExtra="5dp"
            android:layout_marginStart="30dp"
            android:layout_marginTop="150dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="시작 날짜"
            style="@style/TextAppearance.JSG.Body1"
            android:layout_marginBottom="10dp"
            android:layout_marginStart="30dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tv_travelDate_set_startDate"
            />

        <TextView
            android:id="@+id/tv_travelDate_set_startDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="시작 날짜를 선택해주세요"
            android:background="@drawable/shape_rect_5_white_fill_gray400_line_2"
            style="@style/TextAppearance.JSG.Body1"
            android:inputType="none"
            android:dropDownHeight="wrap_content"
            android:dropDownWidth="wrap_content"
            android:layout_marginHorizontal="30dp"
            android:layout_marginBottom="50dp"
            android:padding="12dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <ImageView
            android:id="@+id/iv_travelDate_startDate_arrow"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:background="@drawable/ic_arrow_down"
            app:layout_constraintEnd_toEndOf="@id/tv_travelDate_set_startDate"
            app:layout_constraintTop_toTopOf="@id/tv_travelDate_set_startDate"
            app:layout_constraintBottom_toBottomOf="@id/tv_travelDate_set_startDate"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:id="@+id/tv_travelDate_end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="종료 날짜"
            style="@style/TextAppearance.JSG.Body1"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="10dp"
            android:layout_marginStart="30dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_travelDate_set_startDate"
            />

        <TextView
            android:id="@+id/tv_travelDate_set_endDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="종료 날짜를 선택해주세요"
            android:background="@drawable/shape_rect_5_white_fill_gray400_line_2"
            style="@style/TextAppearance.JSG.Body1"
            android:inputType="none"
            android:dropDownHeight="wrap_content"
            android:dropDownWidth="wrap_content"
            android:layout_marginHorizontal="30dp"
            android:layout_marginBottom="50dp"
            android:padding="12dp"
            android:layout_marginTop="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_travelDate_end"/>

        <ImageView
            android:id="@+id/iv_travelDate_endDate_arrow"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:background="@drawable/ic_arrow_down"
            app:layout_constraintEnd_toEndOf="@id/tv_travelDate_set_endDate"
            app:layout_constraintTop_toTopOf="@id/tv_travelDate_set_endDate"
            app:layout_constraintBottom_toBottomOf="@id/tv_travelDate_set_endDate"
            android:layout_marginEnd="12dp"/>

        <View
            android:id="@+id/view_travelDate_confirm_btn"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/btn_next"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintWidth_percent="0.15"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_margin="30dp"/>
        
        <!-- bottomSheet background -->
        <View
            android:id="@+id/view_travelDate_bottomSheet_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bottomsheet_background"
            android:visibility="gone"/>
        
        <!-- DatePicker Start -->
        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_bottom_sheet_date_start"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
                app:layout_constraintBottom_toBottomOf="parent"
                android:background="@drawable/shape_bottom_sheet">

                <com.google.android.material.bottomsheet.BottomSheetDragHandleView
                    android:id="@+id/drag_handle_date_start"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"/>

                <DatePicker
                    android:id="@+id/picker_date_start"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:theme="@style/JSG.DatePicker"
                    android:calendarViewShown="false"
                    android:datePickerMode="calendar"
                    android:scaleX="1.2"
                    android:scaleY="1.2"
                    android:layout_marginTop="-50dp"
                    app:layout_constraintTop_toBottomOf="@id/drag_handle_date_start"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <TextView
                    android:id="@+id/tv_travelDate_start_save_btn"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:text="저장"
                    android:textColor="@color/white"
                    android:gravity="center"
                    style="@style/TextAppearance.JSG.Button"
                    android:background="@drawable/shape_rect_999_blue_main_fill"
                    app:layout_constraintDimensionRatio="8:1"
                    app:layout_constraintWidth_percent="0.9"
                    app:layout_constraintTop_toBottomOf="@id/picker_date_start"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="40dp"
                    android:layout_marginBottom="20dp"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.coordinatorlayout.widget.CoordinatorLayout>
        
        <!-- DatePicker End -->
        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_bottom_sheet_date_end"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
                app:layout_constraintBottom_toBottomOf="parent"
                android:background="@drawable/shape_bottom_sheet">

                <com.google.android.material.bottomsheet.BottomSheetDragHandleView
                    android:id="@+id/drag_handle_date_end"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"/>

                <DatePicker
                    android:id="@+id/picker_date_end"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:theme="@style/JSG.DatePicker"
                    android:calendarViewShown="false"
                    android:datePickerMode="calendar"
                    android:scaleX="1.2"
                    android:scaleY="1.2"
                    android:layout_marginTop="-50dp"
                    app:layout_constraintTop_toBottomOf="@id/drag_handle_date_end"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <TextView
                    android:id="@+id/tv_travelDate_end_save_btn"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:text="저장"
                    android:textColor="@color/white"
                    android:gravity="center"
                    style="@style/TextAppearance.JSG.Button"
                    android:background="@drawable/shape_rect_999_blue_main_fill"
                    app:layout_constraintDimensionRatio="8:1"
                    app:layout_constraintWidth_percent="0.9"
                    app:layout_constraintTop_toBottomOf="@id/picker_date_end"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="40dp"
                    android:layout_marginBottom="20dp"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.coordinatorlayout.widget.CoordinatorLayout>
        
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>