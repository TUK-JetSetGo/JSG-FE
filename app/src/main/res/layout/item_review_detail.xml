<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_reviewDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/shape_rect_10_gray300_fill"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginHorizontal="20dp">

            <TextView
                android:id="@+id/tv_reviewDetail_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="~일차 후기"
                style="@style/TextAppearance.JSG.Head1"
                android:textSize="16sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_margin="20dp"
                />

            <ImageView
                android:id="@+id/iv_reviewDetail_star"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:background="@drawable/ic_star"
                app:layout_constraintStart_toEndOf="@id/tv_reviewDetail_title"
                app:layout_constraintTop_toTopOf="@id/tv_reviewDetail_title"
                app:layout_constraintBottom_toBottomOf="@id/tv_reviewDetail_title"
                android:layout_marginStart="10dp"/>

            <TextView
                android:id="@+id/tv_reviewDetail_star"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4.5"
                style="@style/TextAppearance.JSG.Body1"
                android:textSize="16sp"
                android:textColor="#ee4444"
                android:layout_marginStart="3dp"
                app:layout_constraintStart_toEndOf="@id/iv_reviewDetail_star"
                app:layout_constraintTop_toTopOf="@id/iv_reviewDetail_star"
                app:layout_constraintBottom_toBottomOf="@id/iv_reviewDetail_star"
                />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_reviewDetail_picture"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_reviewDetail_title"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"/>

            <TextView
                android:id="@+id/tv_reviewDetail_content"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="어디에서 무엇을 즐겼더니 좋았습니다 어쩌고저쩌고 어쩌고저쩌고 어쩌고저쩌고 어쩌고저쩌고 \n어쩌고저쩌고"
                style="@style/TextAppearance.JSG.Body2"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rv_reviewDetail_picture"
                android:layout_marginHorizontal="20dp"
                android:layout_marginVertical="16dp"
                />

            <View
                android:layout_width="20dp"
                android:layout_height="20dp"
                app:layout_constraintTop_toBottomOf="@id/tv_reviewDetail_content"
                app:layout_constraintStart_toStartOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:layout_width="20dp"
            android:layout_height="20dp"
            app:layout_constraintTop_toBottomOf="@id/cl_reviewDetail"
            app:layout_constraintStart_toStartOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>