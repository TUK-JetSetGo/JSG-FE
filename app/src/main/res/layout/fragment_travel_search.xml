<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/shape_rect_10_gray500_shadow"
            app:layout_constraintStart_toStartOf="@id/tv_travelSearch_search"
            app:layout_constraintEnd_toEndOf="@id/tv_travelSearch_search"
            app:layout_constraintTop_toTopOf="@id/tv_travelSearch_search"
            app:layout_constraintBottom_toBottomOf="@id/tv_travelSearch_search"
            android:layout_marginBottom="-10dp"
            android:alpha="0.25"/>


        <TextView
            android:id="@+id/tv_travelSearch_search"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="장소를 입력해주세요"
            android:background="@drawable/shape_rect_10_white_fill_gray400_line_1"
            style="@style/TextAppearance.JSG.Body1"
            android:inputType="none"
            android:dropDownHeight="wrap_content"
            android:dropDownWidth="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:padding="12dp"
            android:paddingStart="35dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <ImageView
            android:id="@+id/iv_travelSearch_arrow"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/ic_arrow_left"
            app:layout_constraintDimensionRatio="1:2"
            app:layout_constraintStart_toStartOf="@id/tv_travelSearch_search"
            app:layout_constraintTop_toTopOf="@id/tv_travelSearch_search"
            app:layout_constraintBottom_toBottomOf="@id/tv_travelSearch_search"
            android:layout_margin="12dp"/>


        <ImageView
            android:id="@+id/iv_travelSearch_delete"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintEnd_toStartOf="@id/iv_travelSearch_search"
            app:layout_constraintTop_toTopOf="@id/tv_travelSearch_search"
            app:layout_constraintBottom_toBottomOf="@id/tv_travelSearch_search"
            android:background="@drawable/ic_close"
            app:layout_constraintDimensionRatio="1:1"
            android:layout_margin="16dp"/>

        <ImageView
            android:id="@+id/iv_travelSearch_search"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintEnd_toEndOf="@id/tv_travelSearch_search"
            app:layout_constraintTop_toTopOf="@id/tv_travelSearch_search"
            app:layout_constraintBottom_toBottomOf="@id/tv_travelSearch_search"
            android:background="@drawable/ic_search"
            app:layout_constraintDimensionRatio="1:1"
            android:layout_margin="14dp"/>

        <TextView
            android:id="@+id/tv_travelSearch_last"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="최근검색"
            style="@style/TextAppearance.JSG.Head1"
            android:textSize="18dp"
            android:lineSpacingExtra="5dp"
            android:layout_marginTop="80dp"
            app:layout_constraintStart_toStartOf="@id/tv_travelSearch_search"
            app:layout_constraintTop_toTopOf="@id/tv_travelSearch_search"/>

        <TextView
            android:id="@+id/tv_travelSearch_delete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="모두 지우기"
            style="@style/TextAppearance.JSG.Body1"
            android:textColor="@color/gray_400"
            android:textSize="14dp"
            android:lineSpacingExtra="5dp"
            app:layout_constraintEnd_toEndOf="@id/tv_travelSearch_search"
            app:layout_constraintTop_toTopOf="@id/tv_travelSearch_last"
            app:layout_constraintBottom_toBottomOf="@id/tv_travelSearch_last"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_travelSearch"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_travelSearch_last"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            tools:listitem="@layout/item_last_search"
            android:orientation="vertical"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>