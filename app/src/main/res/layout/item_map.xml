<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_map"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@color/white">

        <View
            android:id="@+id/view_line"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/gray_300"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/tv_map_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="방문지 이름"
            style="@style/TextAppearance.JSG.Head1"
            android:textSize="16dp"
            android:layout_marginStart="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_margin="20dp"
            />

        <ImageView
            android:id="@+id/iv_map_star"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:background="@drawable/ic_star"
            app:layout_constraintStart_toEndOf="@id/tv_map_name"
            app:layout_constraintTop_toTopOf="@id/tv_map_name"
            app:layout_constraintBottom_toBottomOf="@id/tv_map_name"
            android:layout_marginStart="10dp"/>

        <TextView
            android:id="@+id/tv_map_star"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4.5"
            style="@style/TextAppearance.JSG.Body1"
            android:textSize="14sp"
            android:textColor="#ee4444"
            android:layout_marginStart="3dp"
            app:layout_constraintStart_toEndOf="@id/iv_map_star"
            app:layout_constraintTop_toTopOf="@id/iv_map_star"
            app:layout_constraintBottom_toBottomOf="@id/iv_map_star"
            />

        <View
            android:id="@+id/view_map_add_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/ic_plus_btn"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_margin="20dp"/>

        <TextView
            android:id="@+id/tv_map_address"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="주소 어쩌고 저쩌고"
            style="@style/TextAppearance.JSG.Body1"
            android:textSize="14dp"
            android:textColor="@color/black_700"
            app:layout_constraintStart_toStartOf="@id/tv_map_name"
            app:layout_constraintTop_toBottomOf="@id/tv_map_name"
            android:layout_marginTop="10dp"
            />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_map_keyword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_map_address"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="10dp"
            tools:listitem="@layout/item_keyword"
            android:orientation="horizontal"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_map_picture"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rv_map_keyword"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"/>

        <View
            android:layout_width="20dp"
            android:layout_height="20dp"
            app:layout_constraintTop_toBottomOf="@id/rv_map_picture"
            app:layout_constraintStart_toStartOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>