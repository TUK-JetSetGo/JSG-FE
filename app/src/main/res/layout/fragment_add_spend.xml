<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_addSpend_topbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="20dp"
            android:background="@color/white"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_addSpend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="지출 기록하기"
                android:textSize="20sp"
                style="@style/TextAppearance.JSG.Topbar"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
            <ImageView
                android:id="@+id/iv_addSpend_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_arrow_left"
                android:layout_marginStart="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_addSpend"
                app:layout_constraintBottom_toBottomOf="@id/tv_addSpend"/>
            <TextView
                android:id="@+id/tv_addSpend_complete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="완료"
                android:textSize="18sp"
                android:textColor="@color/gray_900"
                android:layout_marginEnd="20dp"
                style="@style/TextAppearance.JSG.Topbar"
                app:layout_constraintTop_toTopOf="@id/tv_addSpend"
                app:layout_constraintBottom_toBottomOf="@id/tv_addSpend"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <View
            android:id="@+id/view_line"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/gray_300"
            app:layout_constraintTop_toBottomOf="@id/layout_addSpend_topbar"
            app:layout_constraintStart_toStartOf="parent"/>
        
        <!-- 본문 -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/layout_addSpend_topbar"
            app:layout_constraintBottom_toBottomOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/tv_addSpend_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="지출 제목"
                    style="@style/TextAppearance.JSG.Body1"
                    android:layout_marginStart="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:layout_margin="30dp"
                    />

                <EditText
                    android:id="@+id/et_addSpend_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="ex) 편의점"
                    android:background="@drawable/shape_rect_5_white_fill_gray400_line_2"
                    style="@style/TextAppearance.JSG.Body1"
                    android:layout_marginHorizontal="30dp"
                    android:layout_marginTop="10dp"
                    android:padding="12dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_addSpend_title"/>

                <TextView
                    android:id="@+id/tv_addSpend_payer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="결제자"
                    style="@style/TextAppearance.JSG.Body1"
                    android:layout_marginStart="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/et_addSpend_title"
                    android:layout_margin="30dp"
                    />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_payer"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_addSpend_payer"
                    android:layout_marginTop="10dp"
                    android:layout_marginHorizontal="30dp"
                    android:orientation="horizontal"
                    tools:listitem="@layout/item_add_spend_category"/>

                <TextView
                    android:id="@+id/tv_addSpend_participants"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="참여자"
                    style="@style/TextAppearance.JSG.Body1"
                    android:layout_marginStart="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/rv_payer"
                    android:layout_margin="30dp"
                    />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_participants"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_addSpend_participants"
                    android:layout_marginTop="10dp"
                    android:layout_marginHorizontal="30dp"
                    android:orientation="horizontal"
                    tools:listitem="@layout/item_add_spend_category"/>

                <TextView
                    android:id="@+id/tv_addSpend_paymentMethod"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="정산 방법"
                    style="@style/TextAppearance.JSG.Body1"
                    android:layout_marginStart="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/rv_participants"
                    android:layout_margin="30dp"
                    />

                <TextView
                    android:id="@+id/tv_addSpend_split"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="더치페이"
                    android:background="@drawable/shape_rect_999_blue_main_fill"
                    style="@style/TextAppearance.JSG.Body2"
                    android:textSize="16sp"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="18dp"
                    android:layout_marginTop="10dp"
                    app:layout_constraintStart_toStartOf="@id/tv_addSpend_paymentMethod"
                    app:layout_constraintTop_toBottomOf="@id/tv_addSpend_paymentMethod"/>

                <View
                    android:id="@+id/view_4"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    app:layout_constraintStart_toEndOf="@id/tv_addSpend_split"
                    app:layout_constraintTop_toTopOf="@id/tv_addSpend_split"/>

                <TextView
                    android:id="@+id/tv_addSpend_individual"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="각자계산"
                    android:background="@drawable/shape_rect_999_gray300_fill"
                    style="@style/TextAppearance.JSG.Body2"
                    android:textSize="16sp"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="18dp"
                    app:layout_constraintStart_toEndOf="@id/view_4"
                    app:layout_constraintTop_toTopOf="@id/tv_addSpend_split"/>

                <!-- 더치페이 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cl_addSpend_split"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_addSpend_split"
                    android:visibility="visible">

                    <TextView
                        android:id="@+id/tv_addSpend_split_totalPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="총 금액"
                        style="@style/TextAppearance.JSG.Body1"
                        android:layout_marginStart="10dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_margin="30dp"
                        />

                    <EditText
                        android:id="@+id/et_addSpend_split_totalPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:inputType="number"
                        style="@style/TextAppearance.JSG.Body1"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tv_addSpend_split_totalPrice"
                        android:paddingHorizontal="10dp"
                        android:layout_marginEnd="30dp"
                        android:background="@color/transparency"
                        />

                    <View
                        android:layout_width="120dp"
                        android:layout_height="1dp"
                        android:background="@color/gray_400"
                        app:layout_constraintEnd_toEndOf="@id/et_addSpend_split_totalPrice"
                        app:layout_constraintBottom_toBottomOf="@id/et_addSpend_split_totalPrice"
                        android:layout_marginBottom="-4dp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- 각자계산 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cl_addSpend_individual"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_addSpend_split"
                    android:visibility="gone">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_individual"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_marginTop="14dp"
                        android:orientation="vertical"
                        tools:listitem="@layout/item_add_spend_price"/>

                    <TextView
                        android:id="@+id/tv_addSpend_individual_total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="총 금액"
                        style="@style/TextAppearance.JSG.Body1"
                        android:layout_marginStart="30dp"
                        android:layout_marginTop="10dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/rv_individual"
                        />

                    <TextView
                        android:id="@+id/tv_addSpend_individual_totalPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:inputType="number"
                        style="@style/TextAppearance.JSG.Body1"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tv_addSpend_individual_total"
                        android:paddingHorizontal="10dp"
                        android:layout_marginEnd="30dp"
                        android:background="@color/transparency"
                        />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cl_addSpend_individual"/>

                <View
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cl_addSpend_split"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>