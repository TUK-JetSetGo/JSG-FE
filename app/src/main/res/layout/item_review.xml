<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_review"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:background="@drawable/shape_rect_10_gray300_fill"
            android:layout_marginHorizontal="20dp">

            <TextView
                android:id="@+id/tv_review_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="리뷰 제목"
                style="@style/TextAppearance.JSG.Head1"
                android:textSize="16dp"
                android:layout_marginStart="10dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_margin="20dp"
                />

            <TextView
                android:id="@+id/tv_review_nickname"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="닉네임"
                style="@style/TextAppearance.JSG.Body1"
                android:textSize="14dp"
                android:textColor="@color/black_700"
                app:layout_constraintStart_toStartOf="@id/tv_review_title"
                app:layout_constraintTop_toBottomOf="@id/tv_review_title"
                android:layout_marginTop="4dp"
                />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_review_picture"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_review_nickname"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"/>

            <!-- 좋아요 -->
            <View
                android:id="@+id/view_review_like"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:background="@drawable/ic_like"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintStart_toStartOf="@id/tv_review_title"
                app:layout_constraintTop_toBottomOf="@id/rv_review_picture"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/tv_review_like"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12"
                style="@style/TextAppearance.JSG.Body1"
                android:textSize="16dp"
                android:textColor="@color/black_700"
                app:layout_constraintStart_toEndOf="@id/view_review_like"
                app:layout_constraintTop_toTopOf="@id/view_review_like"
                app:layout_constraintBottom_toBottomOf="@id/view_review_like"
                />

            <!-- 댓글 -->
            <View
                android:id="@+id/view_review_comment"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:background="@drawable/ic_comment"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintStart_toEndOf="@id/tv_review_like"
                app:layout_constraintTop_toTopOf="@id/view_review_like"
                android:layout_marginStart="10dp"/>

            <TextView
                android:id="@+id/tv_review_comment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20"
                style="@style/TextAppearance.JSG.Body1"
                android:textSize="16dp"
                android:textColor="@color/black_700"
                app:layout_constraintStart_toEndOf="@id/view_review_comment"
                app:layout_constraintTop_toTopOf="@id/view_review_like"
                app:layout_constraintBottom_toBottomOf="@id/view_review_like"
                android:layout_marginStart="2dp"
                />

            <!-- 북마크 -->
            <View
                android:id="@+id/view_review_bookmark"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:background="@drawable/ic_bookmark"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintStart_toEndOf="@id/tv_review_comment"
                app:layout_constraintTop_toTopOf="@id/view_review_like"
                android:layout_marginStart="10dp"/>

            <TextView
                android:id="@+id/tv_review_bookmark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="14"
                style="@style/TextAppearance.JSG.Body1"
                android:textSize="16dp"
                android:textColor="@color/black_700"
                app:layout_constraintStart_toEndOf="@id/view_review_bookmark"
                app:layout_constraintTop_toTopOf="@id/view_review_like"
                app:layout_constraintBottom_toBottomOf="@id/view_review_like"
                />

            <View
                android:layout_width="20dp"
                android:layout_height="20dp"
                app:layout_constraintTop_toBottomOf="@id/tv_review_like"
                app:layout_constraintStart_toStartOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:layout_width="20dp"
            android:layout_height="20dp"
            app:layout_constraintTop_toBottomOf="@id/cl_review"
            app:layout_constraintStart_toStartOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>