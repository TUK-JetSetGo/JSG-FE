<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_checklist_topbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="20dp"
            android:background="@color/white"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_checklist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="준비물 체크리스트"
                android:textSize="20sp"
                style="@style/TextAppearance.JSG.Topbar"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
            <ImageView
                android:id="@+id/iv_checklist_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_arrow_left"
                android:layout_marginStart="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_checklist"
                app:layout_constraintBottom_toBottomOf="@id/tv_checklist"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <View
            android:id="@+id/view_line"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/gray_300"
            app:layout_constraintTop_toBottomOf="@id/layout_checklist_topbar"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- 본문 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_preset"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_checklist_topbar"
            android:layout_marginTop="20dp"
            android:layout_marginHorizontal="30dp"
            android:orientation="horizontal"
            tools:listitem="@layout/item_category"/>

        <!-- 준비물 목록 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_checklist_items"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="20dp"
            android:layout_marginHorizontal="30dp"
            app:layout_constraintTop_toBottomOf="@id/rv_preset"
            app:layout_constraintBottom_toTopOf="@id/et_add_item"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            tools:listitem="@layout/item_checklist"
            app:spanCount="2" />

        <!-- 준비물 추가 입력창 -->
        <EditText
            android:id="@+id/et_add_item"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            android:hint="준비물을 입력하세요"
            android:background="@drawable/shape_rect_999_gray300_fill"
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/rv_checklist_items"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tv_btn_add_item"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/tv_btn_add_item"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:text="추가"
            style="@style/TextAppearance.JSG.Body1"
            android:background="@drawable/shape_rect_999_blue_main_fill"
            app:layout_constraintTop_toTopOf="@id/et_add_item"
            app:layout_constraintBottom_toBottomOf="@id/et_add_item"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="20dp"
            android:padding="16dp"/>


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>