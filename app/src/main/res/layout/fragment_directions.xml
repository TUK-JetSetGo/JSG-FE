<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <FrameLayout
                android:id="@+id/map_fragment"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="285dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>


        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_bottom_sheet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:behavior_peekHeight="300dp"
            android:background="@drawable/shape_bottom_sheet"
            app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

            <com.google.android.material.bottomsheet.BottomSheetDragHandleView
                android:id="@+id/drag_handle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/shape_rect_10_gray500_shadow"
                app:layout_constraintStart_toStartOf="@id/tv_start_point"
                app:layout_constraintEnd_toEndOf="@id/tv_start_point"
                app:layout_constraintTop_toTopOf="@id/tv_start_point"
                app:layout_constraintBottom_toBottomOf="@id/tv_start_point"
                android:layout_marginBottom="-10dp"
                android:alpha="0.25"/>

            <TextView
                android:id="@+id/tv_start_point"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="출발지"
                android:background="@drawable/shape_rect_10_white_fill_gray400_line_1"
                style="@style/TextAppearance.JSG.Body1"
                android:inputType="none"
                android:dropDownHeight="wrap_content"
                android:dropDownWidth="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="30dp"
                android:padding="12dp"
                android:paddingStart="15dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/shape_rect_10_gray500_shadow"
                app:layout_constraintStart_toStartOf="@id/tv_end_point"
                app:layout_constraintEnd_toEndOf="@id/tv_end_point"
                app:layout_constraintTop_toTopOf="@id/tv_end_point"
                app:layout_constraintBottom_toBottomOf="@id/tv_end_point"
                android:layout_marginBottom="-10dp"
                android:alpha="0.25"/>

            <TextView
                android:id="@+id/tv_end_point"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="도착지"
                android:background="@drawable/shape_rect_10_white_fill_gray400_line_1"
                style="@style/TextAppearance.JSG.Body1"
                android:inputType="none"
                android:dropDownHeight="wrap_content"
                android:dropDownWidth="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:padding="12dp"
                android:paddingStart="15dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_start_point"/>

            <TextView
                android:id="@+id/tv_find_direction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:paddingVertical="5dp"
                android:paddingHorizontal="10dp"
                style="@style/TextAppearance.JSG.Body1"
                android:background="@drawable/shape_rect_10_blue_fill"
                android:paddingStart="35dp"
                app:layout_constraintTop_toBottomOf="@+id/tv_end_point"
                app:layout_constraintEnd_toEndOf="parent"
                android:text="길 찾기"/>

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_map"
                android:layout_marginStart="10dp"
                app:layout_constraintStart_toStartOf="@id/tv_find_direction"
                app:layout_constraintTop_toTopOf="@id/tv_find_direction"
                app:layout_constraintBottom_toBottomOf="@id/tv_find_direction"/>

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayout_schedule_date"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:background="@android:color/transparent"
                app:tabIndicatorColor="@android:color/transparent"
                app:tabRippleColor="@android:color/transparent"
                app:tabIndicatorHeight="0dp"
                app:tabMode="scrollable"
                android:layout_marginTop="15dp"
                app:layout_constraintTop_toBottomOf="@+id/tv_find_direction"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginHorizontal="10dp"/>

            <TextView
                android:id="@+id/tv_my_place"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="내 여행 계획"
                style="@style/TextAppearance.JSG.Body1"
                android:layout_marginTop="20dp"
                android:layout_marginStart="25dp"
                app:layout_constraintTop_toBottomOf="@+id/tabLayout_schedule_date"
                app:layout_constraintStart_toStartOf="parent"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_travelMap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/tv_my_place"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:clipToPadding="false"
                android:paddingBottom="16dp"
                tools:listitem="@layout/item_directions"
                android:orientation="vertical"/>


        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</layout>