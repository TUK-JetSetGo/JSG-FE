<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="활동량을\n선택해주세요"
            style="@style/TextAppearance.JSG.Head1"
            android:lineSpacingExtra="5dp"
            android:layout_marginStart="30dp"
            android:layout_marginTop="150dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/tv_activityLevel_visitCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="하루에 방문할 관광지 개수"
            style="@style/TextAppearance.JSG.Body1"
            android:layout_marginBottom="10dp"
            android:layout_marginStart="30dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tv_activityLevel_time_visitCount"
            />

        <TextView
            android:id="@+id/tv_activityLevel_time_visitCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="개수를 선택해주세요"
            android:background="@drawable/shape_rect_5_white_fill_gray400_line_2"
            style="@style/TextAppearance.JSG.Body1"
            android:inputType="none"
            android:dropDownHeight="wrap_content"
            android:dropDownWidth="wrap_content"
            android:layout_marginHorizontal="30dp"
            android:layout_marginBottom="50dp"
            android:padding="12dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <ImageView
            android:id="@+id/iv_activityLevel_visitCount_arrow"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:background="@drawable/ic_arrow_down"
            app:layout_constraintEnd_toEndOf="@id/tv_activityLevel_time_visitCount"
            app:layout_constraintTop_toTopOf="@id/tv_activityLevel_time_visitCount"
            app:layout_constraintBottom_toBottomOf="@id/tv_activityLevel_time_visitCount"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:id="@+id/tv_activityLevel_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="활동 시작 시간 / 종료 시간"
            style="@style/TextAppearance.JSG.Body1"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="10dp"
            android:layout_marginStart="30dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_activityLevel_time_visitCount"
            />

        <TextView
            android:id="@+id/tv_activityLevel_time_start"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="시작 시간"
            android:background="@drawable/shape_rect_5_white_fill_gray400_line_2"
            style="@style/TextAppearance.JSG.Body1"
            android:inputType="none"
            android:dropDownHeight="wrap_content"
            android:dropDownWidth="wrap_content"
            android:layout_marginHorizontal="30dp"
            android:layout_marginTop="10dp"
            android:padding="12dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tv_activityLevel_text1"
            app:layout_constraintTop_toBottomOf="@id/tv_activityLevel_time"/>

        <ImageView
            android:id="@+id/iv_activityLevel_start_arrow"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:background="@drawable/ic_arrow_down"
            app:layout_constraintEnd_toEndOf="@id/tv_activityLevel_time_start"
            app:layout_constraintTop_toTopOf="@id/tv_activityLevel_time_start"
            app:layout_constraintBottom_toBottomOf="@id/tv_activityLevel_time_start"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:id="@+id/tv_activityLevel_text1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="~"
            style="@style/TextAppearance.JSG.Body1"
            app:layout_constraintStart_toEndOf="@id/tv_activityLevel_time_start"
            app:layout_constraintEnd_toEndOf="@id/tv_activityLevel_time_end"
            app:layout_constraintTop_toTopOf="@id/tv_activityLevel_time_start"
            app:layout_constraintBottom_toBottomOf="@id/tv_activityLevel_time_end"
            />

        <TextView
            android:id="@+id/tv_activityLevel_time_end"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="종료 시간"
            android:background="@drawable/shape_rect_5_white_fill_gray400_line_2"
            style="@style/TextAppearance.JSG.Body1"
            android:inputType="none"
            android:dropDownHeight="wrap_content"
            android:dropDownWidth="wrap_content"
            android:layout_marginHorizontal="30dp"
            android:layout_marginTop="10dp"
            android:padding="12dp"
            app:layout_constraintStart_toEndOf="@id/tv_activityLevel_text1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_activityLevel_time"
            />

        <ImageView
            android:id="@+id/iv_activityLevel_end_arrow"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:background="@drawable/ic_arrow_down"
            app:layout_constraintEnd_toEndOf="@id/tv_activityLevel_time_end"
            app:layout_constraintTop_toTopOf="@id/tv_activityLevel_time_end"
            app:layout_constraintBottom_toBottomOf="@id/tv_activityLevel_time_end"
            android:layout_marginEnd="12dp"/>

        <View
            android:id="@+id/view_activityLevel_confirm_btn"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/btn_next"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintWidth_percent="0.15"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_margin="30dp"/>

        <!-- bottomSheet background -->
        <View
            android:id="@+id/view_activityLevel_bottomSheet_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bottomsheet_background"
            android:visibility="gone"/>

        <!-- TimePicker Start-->
        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_bottom_sheet_time_start"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
                app:layout_constraintBottom_toBottomOf="parent"
                android:background="@drawable/shape_bottom_sheet">

                <com.google.android.material.bottomsheet.BottomSheetDragHandleView
                    android:id="@+id/drag_handle_time_start"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"/>

                <TimePicker
                    android:id="@+id/picker_time_start"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:timePickerMode="spinner"
                    android:theme="@style/JSG.TimePicker"
                    app:layout_constraintTop_toBottomOf="@id/drag_handle_time_start"/>

                <TextView
                    android:id="@+id/tv_activityLevel_start_save_btn"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:text="저장"
                    android:textColor="@color/white"
                    android:gravity="center"
                    style="@style/TextAppearance.JSG.Button"
                    android:background="@drawable/shape_rect_999_blue_main_fill"
                    app:layout_constraintDimensionRatio="8:1"
                    app:layout_constraintWidth_percent="0.9"
                    app:layout_constraintTop_toBottomOf="@id/picker_time_start"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginBottom="20dp"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.coordinatorlayout.widget.CoordinatorLayout>


        <!-- TimePicker End-->
        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_bottom_sheet_time_end"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
                app:layout_constraintBottom_toBottomOf="parent"
                android:background="@drawable/shape_bottom_sheet">

                <com.google.android.material.bottomsheet.BottomSheetDragHandleView
                    android:id="@+id/drag_handle_time_end"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"/>

                <TimePicker
                    android:id="@+id/picker_time_end"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:timePickerMode="spinner"
                    android:theme="@style/JSG.TimePicker"
                    app:layout_constraintTop_toBottomOf="@id/drag_handle_time_end"/>

                <TextView
                    android:id="@+id/tv_activityLevel_end_save_btn"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:text="저장"
                    android:textColor="@color/white"
                    android:gravity="center"
                    style="@style/TextAppearance.JSG.Button"
                    android:background="@drawable/shape_rect_999_blue_main_fill"
                    app:layout_constraintDimensionRatio="8:1"
                    app:layout_constraintWidth_percent="0.9"
                    app:layout_constraintTop_toBottomOf="@id/picker_time_end"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginBottom="20dp"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.coordinatorlayout.widget.CoordinatorLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>