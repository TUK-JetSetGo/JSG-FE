<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_loading_gradient">

        <ImageView
            android:id="@+id/iv_plane"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/ic_plane"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintWidth_percent="0.1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tv_travelLoading_head1"
            android:layout_margin="20dp"/>

        <TextView
            android:id="@+id/tv_travelLoading_head1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="일정 생성 완료!"
            style="@style/TextAppearance.JSG.Head2"
            android:textColor="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginTop="40dp"/>

        <TextView
            android:id="@+id/tv_travelLoading_home_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="홈으로"
            style="@style/TextAppearance.JSG.Button"
            android:textColor="@color/gray_500"
            android:gravity="center"
            android:background="@drawable/shape_rect_20_white_fill"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:paddingVertical="20dp"
            android:paddingHorizontal="30dp"
            android:layout_margin="20dp"/>

        <TextView
            android:id="@+id/tv_travelLoading_travel_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="일정 보러가기"
            style="@style/TextAppearance.JSG.Button"
            android:textColor="@color/white"
            android:gravity="center"
            android:background="@drawable/shape_rect_20_blue_main_fill"
            app:layout_constraintStart_toEndOf="@id/tv_travelLoading_home_btn"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:padding="20dp"
            android:layout_margin="20dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>