<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_createReview_topbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="20dp"
            android:background="@color/white"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_createReview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="리뷰 작성하기"
                android:textSize="20sp"
                style="@style/TextAppearance.JSG.Topbar"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
            <ImageView
                android:id="@+id/iv_createReview_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_arrow_left"
                android:layout_marginStart="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_createReview"
                app:layout_constraintBottom_toBottomOf="@id/tv_createReview"/>
            <TextView
                android:id="@+id/tv_createReview_complete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="완료"
                android:textSize="18sp"
                android:textColor="@color/gray_900"
                android:layout_marginEnd="20dp"
                style="@style/TextAppearance.JSG.Topbar"
                app:layout_constraintTop_toTopOf="@id/tv_createReview"
                app:layout_constraintBottom_toBottomOf="@id/tv_createReview"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <View
            android:id="@+id/view_line"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/gray_300"
            app:layout_constraintTop_toBottomOf="@id/layout_createReview_topbar"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- 본문 -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/layout_createReview_topbar"
            app:layout_constraintBottom_toBottomOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/tv_createReview_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="여행은 어떠셨나요?"
                    style="@style/TextAppearance.JSG.Head1"
                    android:textSize="20sp"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="30dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    />

                <TextView
                    android:id="@+id/tv_createReview_total_comment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="전체 일정에 대한 별점을 남겨주세요"
                    style="@style/TextAppearance.JSG.Body1"
                    android:textSize="16sp"
                    android:textColor="@color/black_500"
                    android:layout_marginTop="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_createReview_total"
                    />

                <RatingBar
                    android:id="@+id/createReview_ratingBar_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:numStars="5"
                    android:stepSize="0.5"
                    android:rating="0"
                    app:layout_constraintTop_toBottomOf="@id/tv_createReview_total_comment"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="6dp"
                    />


                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_createReview"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/createReview_ratingBar_total"
                    android:layout_marginTop="30dp"
                    android:orientation="horizontal"
                    tools:listitem="@layout/item_create_review"/>


            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.core.widget.NestedScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>