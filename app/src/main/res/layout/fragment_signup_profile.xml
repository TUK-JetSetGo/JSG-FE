<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_signup_profile_topbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="20dp"
            android:background="@color/white"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_mypage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="회원가입"
                android:textSize="20sp"
                style="@style/TextAppearance.JSG.Topbar"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
            <ImageView
                android:id="@+id/iv_signup_profile_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_arrow_left"
                android:layout_marginStart="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_mypage"
                app:layout_constraintBottom_toBottomOf="@id/tv_mypage"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <View
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:background="@color/gray_300"
            app:layout_constraintTop_toBottomOf="@id/layout_signup_profile_topbar"
            app:layout_constraintStart_toStartOf="parent"/>

        <View
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:background="@drawable/shape_rect_999_blue_main_fill"
            app:layout_constraintWidth_percent="0.33"
            app:layout_constraintTop_toBottomOf="@id/layout_signup_profile_topbar"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- 본문 -->
        <TextView
            android:id="@+id/tv_signup_profile_head"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="프로필을 설정해주세요"
            style="@style/TextAppearance.JSG.Head1"
            android:textSize="24sp"
            android:textColor="@color/black"
            android:layout_marginStart="30dp"
            android:layout_marginTop="50dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_signup_profile_topbar"/>

        <TextView
            android:id="@+id/tv_signup_profile_body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="최소 1자, 최대 10자 작성 가능해요"
            style="@style/TextAppearance.JSG.Body1"
            android:textSize="14sp"
            android:textColor="@color/gray_500"
            android:layout_marginTop="5dp"
            app:layout_constraintStart_toStartOf="@id/tv_signup_profile_head"
            app:layout_constraintTop_toBottomOf="@id/tv_signup_profile_head"/>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_signup_profile_photo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="70dp">

                <ImageView
                    android:id="@+id/iv_signup_profile_image"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:src="@drawable/ic_profile_default"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <ImageView
                    android:id="@+id/iv_signup_profile_image_edit"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:src="@drawable/ic_edit_btn"
                    app:layout_constraintEnd_toEndOf="@id/iv_signup_profile_image"
                    app:layout_constraintBottom_toBottomOf="@id/iv_signup_profile_image"
                    android:layout_marginTop="50dp"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/tv_signup_profile_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="ex) JetSetGo"
                android:background="@drawable/shape_rect_10_white_fill_gray500_line_1"
                style="@style/TextAppearance.JSG.Body1"
                android:textSize="16sp"
                android:inputType="textNoSuggestions"
                android:layout_marginHorizontal="30dp"
                android:layout_marginTop="50dp"
                android:padding="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cl_signup_profile_photo"/>

            <TextView
                android:id="@+id/tv_signup_profile_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="0"
                style="@style/TextAppearance.JSG.Body2"
                android:textSize="14sp"
                android:textColor="@color/blue_main"
                android:layout_marginTop="5dp"
                app:layout_constraintEnd_toStartOf="@id/tv_signup_profile_10"
                app:layout_constraintTop_toBottomOf="@id/tv_signup_profile_name"/>

            <TextView
                android:id="@+id/tv_signup_profile_10"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="/10"
                style="@style/TextAppearance.JSG.Body2"
                android:textSize="14sp"
                android:textColor="@color/gray_500"
                android:layout_marginTop="5dp"
                android:layout_marginEnd="5dp"
                app:layout_constraintEnd_toEndOf="@id/tv_signup_profile_name"
                app:layout_constraintTop_toBottomOf="@id/tv_signup_profile_name"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:id="@+id/view_signup_profile_next_btn"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/btn_next"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintWidth_percent="0.15"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_margin="30dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>