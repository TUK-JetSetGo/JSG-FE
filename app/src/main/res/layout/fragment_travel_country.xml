<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">
        <!-- top bar -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_addTravel_topbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="20dp"
            android:background="@color/white"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_addTravel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="일정 생성"
                android:textSize="20sp"
                style="@style/TextAppearance.JSG.Topbar"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
            <ImageView
                android:id="@+id/iv_addTravel_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_arrow_left"
                android:layout_marginStart="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_addTravel"
                app:layout_constraintBottom_toBottomOf="@id/tv_addTravel"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/gray_300"
            app:layout_constraintTop_toBottomOf="@id/layout_addTravel_topbar"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- 본문 -->
        <TextView
            android:id="@+id/tv_travel_country_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="여행지를\n선택해주세요"
            style="@style/TextAppearance.JSG.Head1"
            android:lineSpacingExtra="5dp"
            android:layout_marginStart="30dp"
            android:layout_marginTop="150dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/tv_travelCountry_country"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="국가"
            style="@style/TextAppearance.JSG.Body1"
            android:layout_marginTop="50dp"
            android:layout_marginStart="35dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_travel_country_title"
            />

        <Spinner
            android:id="@+id/spinner_travelCountry_country"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginHorizontal="30dp"
            android:dropDownWidth="match_parent"
            android:background="@drawable/shape_rect_5_white_fill_gray400_line_2"
            android:layout_marginTop="10dp"
            android:spinnerMode="dropdown"
            android:dropDownVerticalOffset="42dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_travelCountry_country" />

        <TextView
            android:id="@+id/tv_travelCountry_city"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="시(도)"
            style="@style/TextAppearance.JSG.Body1"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="10dp"
            android:layout_marginStart="30dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/spinner_travelCountry_country"
            />

        <Spinner
            android:id="@+id/spinner_travelCountry_city"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginHorizontal="30dp"
            android:dropDownWidth="match_parent"
            android:background="@drawable/shape_rect_5_white_fill_gray400_line_2"
            android:layout_marginTop="10dp"
            android:spinnerMode="dropdown"
            android:dropDownVerticalOffset="42dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_travelCountry_city"/>

        <View
            android:id="@+id/view_travelCountry_confirm_btn"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/btn_next"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintWidth_percent="0.15"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_margin="30dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>