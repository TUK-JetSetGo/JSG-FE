<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <TextView
            android:id="@+id/tv_modifyReason_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="계획 수정이 필요한\n이유를 알려주세요"
            style="@style/TextAppearance.JSG.Head1"
            android:lineSpacingExtra="5dp"
            android:layout_marginStart="30dp"
            android:layout_marginTop="150dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <RadioGroup
            android:id="@+id/rg_modifyReason"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="40dp"
            android:layout_marginStart="30dp"
            android:layout_marginEnd="30dp"
            app:layout_constraintTop_toBottomOf="@id/tv_modifyReason_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <RadioButton
                android:id="@+id/rb_reason1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="기상 악화"
                style="@style/TextAppearance.JSG.Body1"
                android:buttonTint="@color/blue_main"
                android:paddingStart="10dp"/>

            <RadioButton
                android:id="@+id/rb_reason2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="체력 부족"
                style="@style/TextAppearance.JSG.Body1"
                android:buttonTint="@color/blue_main"
                android:layout_marginTop="10dp"
                android:paddingStart="10dp"/>

            <RadioButton
                android:id="@+id/rb_reason3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="단순 변심"
                style="@style/TextAppearance.JSG.Body1"
                android:buttonTint="@color/blue_main"
                android:layout_marginTop="10dp"
                android:paddingStart="10dp"/>

            <RadioButton
                android:id="@+id/rb_reason4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="기타"
                style="@style/TextAppearance.JSG.Body1"
                android:buttonTint="@color/blue_main"
                android:layout_marginTop="10dp"
                android:paddingStart="10dp"/>
        </RadioGroup>

        <View
            android:id="@+id/view_modifyReason_next_btn"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/btn_next"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintWidth_percent="0.15"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_margin="30dp"
            android:visibility="invisible"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>