<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <!-- top bar -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_signup_theme_topbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="20dp"
            android:background="@color/white"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_signup_theme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="회원가입"
                android:textSize="20sp"
                style="@style/TextAppearance.JSG.Topbar"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
            <ImageView
                android:id="@+id/iv_signup_theme_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_arrow_left"
                android:layout_marginStart="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_signup_theme"
                app:layout_constraintBottom_toBottomOf="@id/tv_signup_theme"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <View
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:background="@color/gray_300"
            app:layout_constraintTop_toBottomOf="@id/layout_signup_theme_topbar"
            app:layout_constraintStart_toStartOf="parent"/>

        <View
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:background="@drawable/shape_rect_999_blue_main_fill"
            app:layout_constraintWidth_percent="0.75"
            app:layout_constraintTop_toBottomOf="@id/layout_signup_theme_topbar"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- 본문 -->
        <TextView
            android:id="@+id/tv_signup_theme_head"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="선호하는 여행 테마를\n설정해주세요"
            style="@style/TextAppearance.JSG.Head1"
            android:textSize="24sp"
            android:textColor="@color/black"
            android:lineSpacingExtra="-5dp"
            android:layout_marginHorizontal="30dp"
            android:layout_marginTop="50dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_signup_theme_topbar"/>

        <TextView
            android:id="@+id/tv_signup_theme_body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="추후 수정 가능해요"
            style="@style/TextAppearance.JSG.Body1"
            android:textSize="14sp"
            android:textColor="@color/gray_500"
            android:layout_marginTop="5dp"
            app:layout_constraintStart_toStartOf="@id/tv_signup_theme_head"
            app:layout_constraintTop_toBottomOf="@id/tv_signup_theme_head"/>

        <TextView
            android:id="@+id/tv_travelTheme_dropDown_theme"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="여행 테마를 선택해주세요"
            android:background="@drawable/shape_rect_5_white_fill_gray400_line_2"
            style="@style/TextAppearance.JSG.Body1"
            android:inputType="none"
            android:dropDownHeight="wrap_content"
            android:dropDownWidth="wrap_content"
            android:layout_marginHorizontal="30dp"
            android:layout_marginBottom="50dp"
            android:padding="12dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <ImageView
            android:id="@+id/iv_travelTheme_arrow"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:background="@drawable/ic_arrow_down"
            app:layout_constraintEnd_toEndOf="@id/tv_travelTheme_dropDown_theme"
            app:layout_constraintTop_toTopOf="@id/tv_travelTheme_dropDown_theme"
            app:layout_constraintBottom_toBottomOf="@id/tv_travelTheme_dropDown_theme"
            android:layout_marginEnd="12dp"/>

        <View
            android:id="@+id/view_travelTheme_confirm_btn"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/btn_next"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintWidth_percent="0.15"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_margin="30dp"/>

        <View
            android:id="@+id/view_travel_theme_background"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/black"
            android:alpha="0.5"
            android:visibility="gone"/>

        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:id="@+id/layout_bottom_sheet_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:behavior_peekHeight="0dp"
                android:orientation="vertical"
                android:background="@drawable/shape_bottom_sheet"
                app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

                <com.google.android.material.bottomsheet.BottomSheetDragHandleView
                    android:id="@+id/drag_handle_theme_bottom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_theme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:listitem="@layout/item_bottom_sheet"
                    android:orientation="vertical"/>

            </LinearLayout>

        </androidx.coordinatorlayout.widget.CoordinatorLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>