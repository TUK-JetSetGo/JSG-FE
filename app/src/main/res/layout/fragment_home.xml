<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/white">

            <TextView
                android:id="@+id/tv_home_jetsetgo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JETSETGO"
                android:textSize="22sp"
                android:textColor="@color/blue_main"
                android:fontFamily="@font/pretendard_extrabold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="20dp"
                android:layout_marginStart="30dp"/>

            <ImageView
                android:id="@+id/iv_home_alert"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_home_jetsetgo"
                app:layout_constraintBottom_toBottomOf="@id/tv_home_jetsetgo"
                android:background="@drawable/ic_alert_blue"
                android:backgroundTint="@color/blue_main"
                android:layout_marginEnd="30dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:background="@drawable/bg_blue_gradient"
                app:layout_constraintTop_toTopOf="@id/rv_home_picture"
                app:layout_constraintBottom_toBottomOf="@id/tv_home_whereToGO"
                android:layout_marginTop="30dp"/>
            
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_home_picture"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_home_jetsetgo"
                android:orientation="horizontal"
                android:layout_marginTop="30dp" />
            
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:background="@drawable/shape_rect_20_white_fill_blue_line_2"
                app:layout_constraintTop_toBottomOf="@id/rv_home_picture"
                app:layout_constraintBottom_toBottomOf="@id/view_1"
                android:layout_marginTop="30dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:background="@color/white"
                app:layout_constraintTop_toTopOf="@id/tv_home_whereToGO"
                app:layout_constraintBottom_toBottomOf="@id/view_1"
                android:layout_marginTop="30dp"/>

            <TextView
                android:id="@+id/tv_home_whereToGO"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="어디로 떠날까요?"
                style="@style/TextAppearance.JSG.Head1"
                android:textSize="18sp"
                android:gravity="center_vertical"
                android:background="@drawable/shape_rect_20_white_fill_blue_line_2"
                app:layout_constraintTop_toBottomOf="@id/rv_home_picture"
                app:layout_constraintStart_toStartOf="parent"
                android:padding="20dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="70dp"/>

            <View
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:background="@drawable/ic_search"
                android:backgroundTint="@color/blue_main"
                app:layout_constraintEnd_toEndOf="@id/tv_home_whereToGO"
                app:layout_constraintTop_toTopOf="@id/tv_home_whereToGO"
                app:layout_constraintBottom_toBottomOf="@id/tv_home_whereToGO"
                android:layout_marginEnd="20dp"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_home_ongoingTrip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/shape_rect_20_white_fill_blue_line_2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_home_whereToGO"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="30dp"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_home_ongoingTrip_head"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="진행중인 여행"
                    style="@style/TextAppearance.JSG.Head1"
                    android:textSize="18sp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:background="@drawable/ic_arrow_down"
                    android:backgroundTint="@color/black"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintStart_toEndOf="@id/tv_home_ongoingTrip_head"
                    app:layout_constraintTop_toTopOf="@id/tv_home_ongoingTrip_head"
                    app:layout_constraintBottom_toBottomOf="@id/tv_home_ongoingTrip_head"
                    android:layout_marginStart="10dp"/>

                <TextView
                    android:id="@+id/tv_home_ongoingTrip_body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="제주  5일 중 2일 째"
                    style="@style/TextAppearance.JSG.Body1"
                    app:layout_constraintTop_toBottomOf="@id/tv_home_ongoingTrip_head"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_marginTop="20dp"/>

                <TextView
                    android:id="@+id/tv_home_ongoingTrip_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2025.04.29 - 2025.05.03"
                    style="@style/TextAppearance.JSG.Body2"
                    android:textColor="@color/gray_700"
                    android:textSize="14sp"
                    app:layout_constraintTop_toTopOf="@id/tv_home_ongoingTrip_body"
                    app:layout_constraintBottom_toBottomOf="@id/tv_home_ongoingTrip_body"
                    app:layout_constraintStart_toEndOf="@id/tv_home_ongoingTrip_body"
                    android:layout_marginStart="10dp"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_home_lastTrip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/shape_rect_20_white_fill_blue_line_2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cl_home_ongoingTrip"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="30dp"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_home_lastTrip_head"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="지난 여행 돌아보기"
                    style="@style/TextAppearance.JSG.Head1"
                    android:textSize="18sp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_home_lastTrip_picture"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_home_lastTrip_head"
                    android:orientation="horizontal"
                    android:layout_marginTop="15dp"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:id="@+id/view_1"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cl_home_lastTrip"/>
            
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</layout>