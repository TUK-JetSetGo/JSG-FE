<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <View
            android:id="@+id/view_home_bg"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="@drawable/bg_loading_gradient"
            android:alpha="0.6"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/iv_home_plane"
            android:layout_marginBottom="-20dp"/>

        <ImageView
            android:id="@+id/iv_home_plane"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:src="@drawable/ic_plane_blue"
            android:layout_margin="20dp"/>

        <ImageView
            android:id="@+id/iv_home_alert"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:src="@drawable/ic_alert_blue"
            android:layout_margin="20dp"/>

        <TextView
            android:id="@+id/tv_home_whereToGO"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="어디로 갈까요?"
            style="@style/TextAppearance.JSG.Body1"
            android:gravity="center_vertical"
            android:background="@drawable/shape_rect_10_gray300_fill"
            app:layout_constraintTop_toBottomOf="@id/iv_home_plane"
            app:layout_constraintStart_toStartOf="parent"
            android:padding="20dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="30dp"/>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_home_ongoingTrip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/shape_rect_10_gray300_fill"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_home_whereToGO"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="30dp"
            android:padding="20dp">

            <TextView
                android:id="@+id/tv_home_ongoingTrip_head"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="진행중인 여행"
                style="@style/TextAppearance.JSG.Body1"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tv_home_ongoingTrip_body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="한국 5일 중 2일 째"
                style="@style/TextAppearance.JSG.Body1"
                app:layout_constraintTop_toBottomOf="@id/tv_home_ongoingTrip_head"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/tv_home_ongoingTrip_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2024.01.01 - 2024.01.05"
                style="@style/TextAppearance.JSG.Body2"
                android:textSize="14sp"
                app:layout_constraintTop_toTopOf="@id/tv_home_ongoingTrip_body"
                app:layout_constraintBottom_toBottomOf="@id/tv_home_ongoingTrip_body"
                app:layout_constraintStart_toEndOf="@id/tv_home_ongoingTrip_body"
                android:layout_marginStart="10dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tv_home_howAboutThis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="이런 여행은 어때요?"
            style="@style/TextAppearance.JSG.Body1"
            android:gravity="center_vertical"
            android:background="@drawable/shape_rect_10_gray300_fill"
            app:layout_constraintTop_toBottomOf="@id/cl_home_ongoingTrip"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:padding="20dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="30dp"/>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_home_ai_recommend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/shape_rect_10_gray300_fill"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_home_howAboutThis"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="30dp"
            android:padding="20dp">

            <TextView
                android:id="@+id/tv_home_aiRecommend_head"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI가 추천하는 소도시 여행"
                style="@style/TextAppearance.JSG.Body1"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_home_aiRecommend_picture"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_home_aiRecommend_head"
                android:orientation="horizontal"
                android:layout_marginTop="15dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>