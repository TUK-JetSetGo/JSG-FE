<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_review"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:background="@drawable/shape_rect_10_gray300_fill"
            android:layout_marginHorizontal="20dp">

            <TextView
                android:id="@+id/tv_createReview_day"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1일차"
                style="@style/TextAppearance.JSG.Head1"
                android:textSize="18sp"
                android:layout_marginStart="10dp"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                />

            <RatingBar
                android:id="@+id/createReview_ratingBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:numStars="5"
                android:stepSize="0.5"
                android:rating="0"
                android:scaleY="0.7"
                android:scaleX="0.7"
                android:progressTint="@color/blue_deep"
                app:layout_constraintTop_toBottomOf="@id/tv_createReview_day"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="-22dp"
                android:layout_marginTop="6dp"
                />

            <EditText
                android:id="@+id/et_createReview_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:gravity="left"
                android:hint="자세한 후기를 들려주세요"
                android:background="@drawable/shape_rect_5_white_fill_gray400_line_2"
                style="@style/TextAppearance.JSG.Body2"
                android:textSize="16sp"
                android:layout_marginHorizontal="10dp"
                android:padding="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/createReview_ratingBar"/>

            <View
                android:layout_width="20dp"
                android:layout_height="20dp"
                app:layout_constraintTop_toBottomOf="@id/et_createReview_title"
                app:layout_constraintStart_toStartOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:layout_width="20dp"
            android:layout_height="20dp"
            app:layout_constraintTop_toBottomOf="@id/cl_review"
            app:layout_constraintStart_toStartOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>