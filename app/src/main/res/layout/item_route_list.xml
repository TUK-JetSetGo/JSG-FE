<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_route_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:background="@drawable/shape_rect_10_blue2_fill"
            android:layout_marginHorizontal="20dp">

            <TextView
                android:id="@+id/tv_route_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="가장 빠른 경로"
                style="@style/TextAppearance.JSG.Head1"
                android:textColor="@color/blue_deep"
                android:textSize="15sp"
                android:layout_marginTop="20dp"
                android:layout_marginStart="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"

                />

            <TextView
                android:id="@+id/tv_route_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30분"
                style="@style/TextAppearance.JSG.Body1"
                android:textSize="30sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="35dp"
                android:layout_marginStart="20dp"
                />

            <ImageView
                android:id="@+id/iv_route_bus"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:src="@drawable/ic_bus"
                android:layout_marginEnd="10dp"
                app:layout_constraintEnd_toStartOf="@+id/tv_bus_number"
                app:layout_constraintTop_toTopOf="@id/tv_bus_number"
                app:layout_constraintBottom_toBottomOf="@id/tv_bus_number"/>

            <TextView
                android:id="@+id/tv_bus_number"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.JSG.Head1"
                android:text="1234"
                android:textColor="#1976D2"
                android:textSize="20sp"
                android:maxLines="1"
                android:maxWidth="200dp"
                android:ellipsize="end"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="12sp"
                app:autoSizeMaxTextSize="20sp"
                android:layout_marginTop="30dp"
                android:layout_marginEnd="15dp"
                android:gravity="center"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <ImageView
                android:id="@+id/iv_route_walk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_walk"
                android:layout_marginTop="20dp"
                android:layout_marginStart="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_route_time"/>

            <TextView
                android:id="@+id/tv_route_walk_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="도보 5분"
                style="@style/TextAppearance.JSG.Body1"
                android:textColor="@color/black_700"
                android:textSize="16sp"
                android:layout_marginStart="10dp"
                app:layout_constraintStart_toEndOf="@+id/iv_route_walk"
                app:layout_constraintTop_toTopOf="@+id/iv_route_walk"
                app:layout_constraintBottom_toBottomOf="@+id/iv_route_walk"/>

            <TextView
                android:id="@+id/tv_route_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="상세 경로"
                style="@style/TextAppearance.JSG.Head1"
                android:textSize="20sp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="30dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/iv_route_walk"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_route_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_route_info"
                android:layout_marginHorizontal="20dp"
                android:orientation="horizontal"
                tools:listitem="@layout/item_route_detail"
                />

            <TextView
                android:id="@+id/tv_route_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="상세보기"
                style="@style/TextAppearance.JSG.Body1"
                android:textSize="16sp"
                android:textColor="@color/black_700"
                android:layout_marginStart="20dp"
                android:layout_marginTop="25dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/iv_route_walk"
                />

            <TextView
                android:id="@+id/tv_route_simple"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="간단히"
                style="@style/TextAppearance.JSG.Body1"
                android:textSize="16dp"
                android:textColor="@color/black_700"
                android:layout_marginStart="20dp"
                android:layout_marginTop="35dp"
                android:paddingBottom="15dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rv_route_detail"
                android:visibility="gone"/>

            <ImageView
                android:id="@+id/iv_route_detail"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_arrow_down"
                android:layout_marginBottom="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="27dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/iv_route_walk"/>

            <View
                android:layout_width="20dp"
                android:layout_height="20dp"
                app:layout_constraintTop_toBottomOf="@id/tv_route_detail"
                app:layout_constraintStart_toStartOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:layout_width="20dp"
            android:layout_height="20dp"
            app:layout_constraintTop_toBottomOf="@id/cl_route_container"
            app:layout_constraintStart_toStartOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>